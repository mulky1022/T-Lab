{
  "services": [
    {
      "name": "backend",
      "type": "docker",
      "dockerfilePath": "backend/Dockerfile",
      "build": {
        "command": "docker build -f backend/Dockerfile -t tlab-backend ."
      },
      "start": {
        "command": "docker run -p 80:80 tlab-backend"
      }
    }
  ]
}
